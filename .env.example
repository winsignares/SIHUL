# ================================================
# .env.example - TEMPLATE VARIABLES DE ENTORNO
# ================================================
# Este es un archivo de EJEMPLO. Para usar:
# 1. Copiar este archivo a .env
# 2. Reemplazar los valores con tus credenciales reales
# 3. NUNCA commitear .env a Git
#
# ⚠️ IMPORTANTE: Este archivo SÍ se commitea a Git
# para que otros desarrolladores sepan qué variables necesitan

# ==========================================
# DATABASE - PostgreSQL
# ==========================================
POSTGRES_DB=mypostgresdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=mypostgresdb

# ==========================================
# PGADMIN
# ==========================================
PGADMIN_DEFAULT_EMAIL=admin@localhost.com
PGADMIN_DEFAULT_PASSWORD=change-me

# ==========================================
# DJANGO BACKEND
# ==========================================
DJANGO_SECRET_KEY=dev-unsafe-do-not-use-in-prod
DEBUG=true

# reCAPTCHA v3 - Obtener en https://www.google.com/recaptcha/admin
# Registrarse en Google Recaptcha Admin Console y crear un nuevo sitio
# Tipo: reCAPTCHA v3
# Dominios: localhost, 127.0.0.1, localhost:8081, tu-dominio.com
RECAPTCHA_SITE_KEY=YOUR_SITE_KEY_HERE
RECAPTCHA_SECRET_KEY=YOUR_SECRET_KEY_HERE

# Chatbot FastAPI
CHATBOT_FASTAPI_URL=http://chatbot:8001/api/v1

# ==========================================
# FRONTEND REACT + VITE
# ==========================================
VITE_API_URL=http://localhost:8000
VITE_RECAPTCHA_SITE_KEY=YOUR_SITE_KEY_HERE
VITE_CHATBOT_URL=http://localhost:8001

# ==========================================
# DOCKER NETWORK
# ==========================================
DOCKER_NETWORK_SUBNET=10.201.2.0/24
DOCKER_NETWORK_GATEWAY=10.201.2.1

# ==========================================
# CHATBOT CONFIGURACIÓN
# ==========================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# ==========================================
# QA TESTS
# ==========================================
QA_TEST_PASSWORD=replace_me
FINANCIERO_DOCUMENT_ROOT=C:\Users\Harlem Hernandez\Documents\Trabajo - UL\Projects\Financiero Facturas

# Carpeta compartida de red NAS Universidad Libre
# Ruta UNC completa. Ejemplo: \\nasul.unilibre.edu.co\BARRANQUILLA\sihulapp
FINANCIERO_DOCUMENT_NETWORK_ROOT=
# Usuario de red para acceder a la carpeta compartida
FINANCIERO_DOCUMENT_NETWORK_USER=
# Contraseña del usuario de red. NO incluir valor real en este archivo.
FINANCIERO_DOCUMENT_NETWORK_PASSWORD=
