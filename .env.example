# Copia este archivo como .env en la raiz del proyecto:
# cp .env.example .env
#
# No subas .env a Git. Aqui van secretos reales de produccion.

# ============================================
# Django / backend
# ============================================

# En produccion debe ser False.
DJANGO_DEBUG=False

# Dominios permitidos por Django, separados por coma si hay varios.
DJANGO_ALLOWED_HOSTS=sihul.unilibre.edu.co

# URL publica del frontend. Despues del login OAuth, Django vuelve a esta URL.
FRONTEND_URL=https://sihul.unilibre.edu.co

# Clave secreta de Django. En produccion usa un valor largo y privado.
# Puedes generar una con:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# ============================================
# Microsoft / Azure Entra ID OAuth
# ============================================

# Azure Portal > App registrations > tu app > Overview > Application (client) ID.
MICROSOFT_CLIENT_ID=

# Azure Portal > App registrations > tu app > Certificates & secrets.
# Crea un Client secret y pega aqui el VALUE, no el Secret ID.
MICROSOFT_CLIENT_SECRET=

# Opciones:
# - common: permite cuentas Microsoft de varios tenants.
# - organizations: permite cuentas laborales/escolares.
# - Tenant ID de tu institucion: restringe solo a Universidad Libre.
MICROSOFT_TENANT=common

# Redirect URI que debes registrar en Azure:
# https://sihul.unilibre.edu.co/accounts/microsoft/login/callback/

# ============================================
# Archivos / NAS Universidad Libre
# ============================================

# Directorio local dentro del contenedor donde Django guarda archivos subidos.
FINANCIERO_DOCUMENT_ROOT=/app/media

# Ruta UNC completa. Ejemplo: \\nasul.unilibre.edu.co\BARRANQUILLA\sihulapp
FINANCIERO_DOCUMENT_NETWORK_ROOT=

# Usuario de red para acceder a la carpeta compartida.
FINANCIERO_DOCUMENT_NETWORK_USER=

# Contraseña del usuario de red. NO incluir valor real en este archivo.
FINANCIERO_DOCUMENT_NETWORK_PASSWORD=

# ============================================
# Red Docker
# ============================================

# Cambia estos valores solo si tu red local choca con la red de Docker.
DOCKER_NETWORK_SUBNET=10.201.2.0/24
DOCKER_NETWORK_GATEWAY=10.201.2.1
