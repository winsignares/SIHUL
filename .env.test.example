# Docker Compose project
COMPOSE_PROJECT_NAME=sihul-test

# Host ports for the isolated test stack
TEST_POSTGRES_PORT=55432
TEST_BACKEND_PORT=8100
TEST_CHATBOT_PORT=8101
TEST_FRONTEND_PORT=5273
TEST_PUBLIC_HOST=10.4.100.146

# Dedicated Docker network, outside the server routes currently in use
TEST_DOCKER_NETWORK_SUBNET=10.202.10.0/24
TEST_DOCKER_NETWORK_GATEWAY=10.202.10.1

# PostgreSQL test database
DB_NAME=sihul_test_db
DB_USER=sihul_test_user
DB_PASSWORD=change_this_test_password

# Django test/staging settings
APP_ENV=test
DJANGO_SECRET_KEY=change-this-test-only-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,10.4.100.146
CORS_ALLOWED_ORIGINS=http://localhost:5273,http://127.0.0.1:5273,http://10.4.100.146:5273
CSRF_TRUSTED_ORIGINS=http://localhost:5273,http://127.0.0.1:5273,http://10.4.100.146:5273
FRONTEND_URL=http://10.4.100.146:5273
SESSION_COOKIE_NAME=sihul_test_sessionid
CSRF_COOKIE_NAME=sihul_test_csrftoken
ETL_PERIODO=20261

# Optional Microsoft OAuth credentials for staging
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Chatbot settings
# Placeholder allows the service to boot. Replace it to test OpenAI calls.
OPENAI_API_KEY=test-key-not-for-production
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Keep network document storage disabled in tests
FINANCIERO_DOCUMENT_NETWORK_ROOT=
FINANCIERO_DOCUMENT_NETWORK_USER=
FINANCIERO_DOCUMENT_NETWORK_PASSWORD=
