# Normalize all text files in the repository to LF.
* text=auto eol=lf

# Windows-native scripts require CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unix scripts must remain executable-friendly.
*.sh text eol=lf

# Binary files must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.xlsx binary
*.xls binary
*.docx binary
*.pptx binary
