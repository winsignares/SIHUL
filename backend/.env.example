# ============================================
# CONFIGURACIÓN DE CREDENCIALES ORACLE
# ============================================
# IMPORTANTE: 
# 1. Copia este archivo a .env en el mismo directorio
# 2. Completa los valores con tus credenciales reales
# 3. NUNCA subas .env a git (está ignorado en .gitignore)
# 4. Mantén .env.example en el repositorio (sin valores sensibles)

# Host del servidor Oracle
ORACLE_HOST=tu_host

# Usuario de Oracle
ORACLE_USER=tu_usuario

# Contraseña de Oracle
ORACLE_PASSWORD=tu_password

# Nombre del servicio Oracle (SID o service name)
ORACLE_SERVICE=tu_servicio

# Puerto (opcional, default es 1521)
ORACLE_PORT=1521
