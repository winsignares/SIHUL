# ================================================
# .env - VARIABLES DE ENTORNO SIHUL
# ⚠️ NUNCA COMMITEAR ESTE ARCHIVO
# Contiene claves secretas y credenciales
# ================================================

# ==========================================
# DATABASE - PostgreSQL
# ==========================================
POSTGRES_DB=mypostgresdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword

DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=mysecretpassword
DB_NAME=mypostgresdb

# ==========================================
# PGADMIN
# ==========================================
PGADMIN_DEFAULT_EMAIL=admin@localhost.com
PGADMIN_DEFAULT_PASSWORD=change-me

# ==========================================
# DJANGO BACKEND
# ==========================================
DJANGO_SECRET_KEY=dev-unsafe-do-not-use-in-prod

